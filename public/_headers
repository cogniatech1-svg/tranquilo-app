# Cloudflare Pages _headers — réplica EXACTA de headers() en next.config.ts.
# En static export, headers() de Next no aplica; Cloudflare Pages sirve estos.
# Se copia a out/_headers en el build.

/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Service-Worker-Allowed: /
  Content-Type: application/javascript; charset=utf-8

/manifest.json
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/manifest+json; charset=utf-8

/icons/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/favicon.png
  Cache-Control: public, max-age=0, must-revalidate

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; connect-src 'self' https:; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests
